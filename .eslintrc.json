{
  "root": true,
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/consistent-type-assertions": [
      "error",
      {
        "assertionStyle": "as",
        "objectLiteralTypeAssertions": "allow-as-parameter"
      }
    ],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-empty": ["error", { "allowEmptyCatch": true }]
  },
  "overrides": [
    {
      "files": ["apps/web/src/lib/**/*.ts", "functions/src/**/*.ts"],
      "excludedFiles": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "selector": "Property > LogicalExpression[operator='||'][right.type='Identifier'][right.name='undefined']",
            "message": "Using `value || undefined` in an object property is a Firestore foot-gun — the property becomes `undefined` and Firestore rejects it. Use a conditional spread instead: `...(value && { key: value })`. See CLAUDE.md rule 12."
          }
        ]
      }
    }
  ],
  "env": {
    "node": true,
    "browser": true,
    "es2020": true
  }
}
