rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Bitwise permission check against the `permissions` custom claim.
    // Mirrors the helper in firestore.rules. Permission bits are defined
    // in packages/constants/src/permissions.ts.
    function hasPermission(permissionBit) {
      return request.auth != null &&
             request.auth.token.permissions != null &&
             math.floor(request.auth.token.permissions / permissionBit) % 2 == 1;
    }

    // Project documents - authenticated users can read and write
    match /projects/{projectId}/documents/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Document uploads (via documentService) - general document storage
    // Path: documents/{projectId}/{module}/{entityType}/{entityId}/{filename}
    match /documents/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Document templates
    // Path: templates/{filename}
    match /templates/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Accounting files - authenticated users can read and write
    match /accounting/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Enquiry files - authenticated users can read and write
    match /enquiries/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Document parsing - temporary uploads for AI parsing
    // Path: parsing/{userId}/{filename}
    // Files are uploaded by client, processed by Cloud Function, then deleted
    match /parsing/{userId}/{allPaths=**} {
      // Read: User can read their own uploads, Cloud Functions have admin access
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Write: Only the authenticated user can write to their own folder
      // Max file size: 10MB (documents can be larger than images)
      allow write: if isAuthenticated() &&
                     request.auth.uid == userId &&
                     request.resource.size < 10 * 1024 * 1024;

      // Delete: User can delete their own files
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Purchase Request attachments - TDS, specs, datasheets, drawings
    // Path: procurement/pr/{prId}/attachments/{filename}
    match /procurement/pr/{prId}/attachments/{allPaths=**} {
      // Read: All authenticated internal users can read PR attachments
      allow read: if isAuthenticated();

      // Write: Users with MANAGE_PROCUREMENT permission can upload
      // Max file size: 25MB (PDFs, drawings can be large)
      allow write: if isAuthenticated() &&
                     request.resource.size < 25 * 1024 * 1024;

      // Delete: Users with MANAGE_PROCUREMENT permission
      allow delete: if isAuthenticated();
    }

    // Feedback screenshots - users can upload to their own folder
    // Path: feedback/{userId}/{filename}
    match /feedback/{userId}/{allPaths=**} {
      // Read: Only admins (for reviewing feedback) or the uploader
      allow read: if isAuthenticated() &&
                    (request.auth.uid == userId ||
                     request.auth.token.permissions != null);

      // Write: Only the authenticated user can write to their own folder
      // Max file size: 5MB
      allow write: if isAuthenticated() &&
                     request.auth.uid == userId &&
                     request.resource.size < 5 * 1024 * 1024 &&
                     request.resource.contentType.matches('image/.*');
    }

    // HR Travel Expense Receipts
    // Path: hr/travel-expenses/{reportId}/receipts/{filename}
    match /hr/travel-expenses/{reportId}/receipts/{allPaths=**} {
      // Read: Authenticated users can read (owner check done at Firestore level)
      allow read: if isAuthenticated();

      // Write: Authenticated users can upload receipts
      // Max file size: 5MB, allowed types: PDF, images
      allow write: if isAuthenticated() &&
                     request.resource.size < 5 * 1024 * 1024 &&
                     (request.resource.contentType.matches('image/.*') ||
                      request.resource.contentType == 'application/pdf');

      // Delete: Authenticated users can delete
      allow delete: if isAuthenticated();
    }

    // RFQ Offers - vendor quotation uploads
    // Path: offers/{rfqId}/{filename}
    match /offers/{rfqId}/{allPaths=**} {
      // Read: Authenticated users can read offers
      allow read: if isAuthenticated();

      // Write: Authenticated users can upload offers
      // Max file size: 25MB (PDFs, Excel files can be large)
      allow write: if isAuthenticated() &&
                     request.resource.size < 25 * 1024 * 1024;

      // Delete: Authenticated users can delete
      allow delete: if isAuthenticated();
    }

    // RFQ PDFs - generated RFQ documents
    // Path: rfq-pdfs/{rfqId}/{filename}
    match /rfq-pdfs/{rfqId}/{allPaths=**} {
      allow read: if isAuthenticated();

      allow write: if isAuthenticated() &&
                     request.resource.size < 25 * 1024 * 1024;

      allow delete: if isAuthenticated();
    }

    // Vendor Offers - quotation documents uploaded via materials module
    // Path: vendor-offers/{timestamp}_{filename}
    match /vendor-offers/{allPaths=**} {
      allow read: if isAuthenticated();

      allow write: if isAuthenticated() &&
                     request.resource.size < 25 * 1024 * 1024;

      allow delete: if isAuthenticated();
    }

    // Vendor Quotes - quotation documents uploaded via the procurement
    // "Log Vendor Quote" page (incl. the staging path used by the AI parser
    // before the quote is saved).
    // Path: vendor-quotes/{timestamp}_{filename} or vendor-quotes/staging/...
    //
    // Read: any internal user who can VIEW procurement.
    // Write/Delete: gated on MANAGE_PROCUREMENT (bit 16 = 65536) so a
    // viewer-only account can't upload or wipe a quote PDF.
    match /vendor-quotes/{allPaths=**} {
      allow read: if isAuthenticated();

      allow write: if hasPermission(65536) &&
                     request.resource.size < 25 * 1024 * 1024;

      allow delete: if hasPermission(65536);
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
