echo "🔍 Running pre-commit checks..."

# Run lint-staged (format and lint changed files)
pnpm lint-staged

# TypeScript type checking for web app
echo "🔍 Running TypeScript type check..."
pnpm exec tsc --noEmit --project apps/web/tsconfig.json
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed!"
  exit 1
fi

# Type safety check (detect 'as any' and other unsafe patterns)
echo "🔍 Running type safety check..."
if grep -r "as any" apps/web/src --include="*.ts" --include="*.tsx" 2>/dev/null | grep -v "node_modules"; then
  echo "❌ Found 'as any' type casts! Please use proper typing instead."
  echo "   See docs/TYPESCRIPT_GUIDELINES.md for guidance."
  exit 1
fi
echo "✅ No prohibited type casts found"

# Validate Firebase hosting rewrites match dynamic routes
echo "🔍 Validating Firebase hosting rewrites..."
node scripts/validate-firebase-rewrites.js
if [ $? -ne 0 ]; then
  echo "❌ Firebase hosting rewrites validation failed!"
  echo "   Add missing rewrites to firebase.json before the catch-all rule."
  exit 1
fi

# Run pre-deployment checks (skip build and schema for speed)
node scripts/preflight/pre-deployment-check.js --skip-build --skip-schema

# If checks fail, prevent commit
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Pre-commit checks failed. Fix critical issues before committing."
  echo "   To skip this check (not recommended), use: git commit --no-verify"
  exit 1
fi

# Tenant ID safety check (blocking — prevents entityId/tenantId regressions)
node scripts/check-tenant-id-safety.js
if [ $? -ne 0 ]; then
  echo "❌ Tenant ID safety check failed! See output above."
  exit 1
fi

# Breadcrumb duplication check (blocking — prevents "two breadcrumb bars" bug)
node scripts/check-breadcrumb-duplication.js
if [ $? -ne 0 ]; then
  echo "❌ Breadcrumb safety check failed! See output above."
  exit 1
fi

# Agent-readiness rule audit. Per-rule enforcement: rules listed in
# scripts/audit/enforced-rules.json block the commit on regression; all other
# rule violations are reported but advisory.
echo "🔍 Running CLAUDE.md rule audit..."
node scripts/audit/check-rules.js --quiet
if [ $? -ne 0 ]; then
  echo "❌ Rule audit failed: regression on an enforced rule. See output above."
  echo "   To bypass for this commit only (not recommended): git commit --no-verify"
  exit 1
fi

# UI/UX standardisation guardrails (docs/archive/2026-07-03-ui-ux-standardisation-plan.md
# Phase 5). Self-contained enforcement policy in scripts/audit/ui-baselines.json:
# zero-tolerance categories block once clean, count-ratchets block on regression.
echo "🔍 Running UI/UX standards check..."
node scripts/audit/check-ui-standards.js --quiet
if [ $? -ne 0 ]; then
  echo "❌ UI standards check failed. See output above."
  echo "   To bypass for this commit only (not recommended): git commit --no-verify"
  exit 1
fi

# Test-presence ratchet (docs/archive/2026-07-05-automated-verification-plan.md
# Phase 6). New service/function files must ship with a test; the pre-existing
# untested backlog is frozen in scripts/audit/test-baselines.json and may only
# shrink (stale entries block until removed).
echo "🔍 Running test-presence check..."
node scripts/audit/check-test-presence.js --quiet
if [ $? -ne 0 ]; then
  echo "❌ Test-presence check failed. See output above."
  echo "   To bypass for this commit only (not recommended): git commit --no-verify"
  exit 1
fi

# Functions lockfile-sync guard. The Cloud Functions deploy runs `npm ci`
# against functions/package-lock.json (a SEPARATE npm lockfile from the root
# pnpm-lock.yaml). If functions/package.json changes without regenerating the
# lock, the deploy fails at build time with "npm ci ... not in sync". Catch it
# here. Only runs when a functions manifest is staged, so normal commits stay fast.
if git diff --cached --name-only | grep -qE '^functions/(package\.json|package-lock\.json)$'; then
  echo "🔍 Verifying functions/package-lock.json is in sync (deploy runs npm ci)..."
  (cd functions && npm ci --dry-run --no-audit --no-fund) >/dev/null 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ functions/package.json and functions/package-lock.json are out of sync."
    echo "   The Firebase deploy runs 'npm ci' here and will fail. To fix:"
    echo "     (cd functions && npm install) && git add functions/package-lock.json"
    echo "   To bypass for this commit only (not recommended): git commit --no-verify"
    exit 1
  fi
  echo "✅ functions lockfile in sync"
fi

# Production dependency security audit — mirrors the CI "Security Audit" job
# (pnpm audit --production --audit-level=high), which has been the ONLY CI
# failure we've hit. Catch high-severity advisories here instead of at CI.
# --ignore-registry-errors keeps offline commits working (it only fails on
# actual high-severity findings, not on registry-unreachable).
echo "🔍 Running security audit (production, high-severity)..."
pnpm audit --production --audit-level=high --ignore-registry-errors
if [ $? -ne 0 ]; then
  echo "❌ Security audit found high-severity vulnerabilities (same gate as CI)."
  echo "   Fix before committing — usually a pnpm.overrides entry in package.json"
  echo "   forcing the patched version (see the @grpc/protobufjs/form-data/nodemailer"
  echo "   overrides for examples)."
  echo "   To bypass for this commit only (not recommended): git commit --no-verify"
  exit 1
fi
echo "✅ Security audit passed"

echo "✅ Pre-commit checks passed!"
